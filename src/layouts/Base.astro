---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  /** shown top-right in the header, e.g. "Essay 02 / 05" */
  folio?: string;
  current?: string;
}
const { title, description, folio, current } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#efe9dd" />
    <meta name="color-scheme" content="light" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link
      rel="icon"
      href={`data:image/svg+xml,${encodeURIComponent(
        `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64"><rect width="64" height="64" fill="#efe9dd"/><text x="32" y="46" font-family="Georgia,serif" font-weight="900" font-size="42" text-anchor="middle" fill="#7a2233">¶</text></svg>`
      )}`}
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,600;0,9..144,900;1,9..144,600&family=IBM+Plex+Mono:wght@400;500&family=Spectral:ital,wght@0,400;0,500;1,400;1,500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="paper" aria-hidden="true"></div>

    <a
      href="#main"
      class="meta"
      style="position:absolute;left:-200vw;top:0;background:var(--bg-lift);padding:.6rem 1rem;z-index:99"
      onfocus="this.style.left='1rem';this.style.top='1rem'"
      onblur="this.style.left='-200vw'"
    >
      Skip to content
    </a>

    <header class="wrap site-head">
      <a class="brand" href={`${base}/`}>The Marginalia<span style="color:var(--oxblood)">.</span></a>
      <nav class="site-nav" aria-label="Site">
        <a href={`${base}/#contents`} aria-current={current === 'contents' ? 'page' : undefined}>Contents</a>
        <a href={`${base}/#letters`}>Letters</a>
        <a href={`${base}/#subscribe`}>Subscribe</a>
        {folio ? <a href={`${base}/#contents`} style="color:var(--oxblood)">{folio}</a> : <a href={`${base}/guide/`}>Guide</a>}
      </nav>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="wrap site-foot">
      <div class="foot-grid">
        <span class="meta">The Marginalia · № 14 · Summer 2026</span>
        <span class="meta"><a href={`${base}/#contents`}>Contents</a> · <a href={`${base}/#subscribe`}>Subscribe</a></span>
        <span class="credit">Designed &amp; built by Parable · <a href={`${base}/guide/`}>How this was built →</a></span>
      </div>
    </footer>

    <script>
      // progressive-enhancement gate: the class lives WITH the code that needs it,
      // so motion/folding styles only ever apply when this module actually runs.
      document.documentElement.classList.add('js');

      // shared: reveal-on-scroll.
      // Anything already inside the viewport reveals synchronously (no first-paint
      // flicker, works even if observer callbacks never fire); the rest waits for IO.
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const revealed = Array.from(document.querySelectorAll('.reveal'));
      const below = revealed.filter((el) => {
        const r = el.getBoundingClientRect();
        const inView = r.top < window.innerHeight && r.bottom > 0;
        if (inView) el.classList.add('in');
        return !inView;
      });
      if (!reduce && 'IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('in');
                io.unobserve(e.target);
              }
            }
          },
          { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
        );
        below.forEach((el) => io.observe(el));
      } else {
        below.forEach((el) => el.classList.add('in'));
      }
    </script>
  </body>
</html>
